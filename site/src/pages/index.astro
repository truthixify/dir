---
import Base from "../layouts/Base.astro";
import { getIdeas, DIFFICULTY_ORDER, DIFFICULTY_LABEL, STATUS_LABEL } from "../lib/ideas.js";

const ideas = getIdeas();
const categories = [...new Set(ideas.map((i) => i.category))].sort();
const properties = [...new Set(ideas.flatMap((i) => i.ckb_properties))].sort();
const difficulties = DIFFICULTY_ORDER.filter((d) => ideas.some((i) => i.difficulty === d));
---

<Base>
  <section class="hero">
    <div class="wrap">
      <h1>Build something <span class="lead-accent">CKB-native</span>.</h1>
      <p>
        {ideas.length} project ideas that exploit what only CKB can do — the Cell model, Spore/DOB,
        RGB++, Fiber, OTX, and on-chain verification. Pick one, commit publicly, ship it.
      </p>
    </div>
  </section>

  <div class="wrap">
    <div class="filters">
      <input type="search" id="q" placeholder="Search ideas…" autocomplete="off" />
      <select id="category">
        <option value="">All categories</option>
        {categories.map((c) => <option value={c}>{c}</option>)}
      </select>
      <select id="difficulty">
        <option value="">Any difficulty</option>
        {difficulties.map((d) => <option value={d}>{DIFFICULTY_LABEL[d]}</option>)}
      </select>
      <select id="property">
        <option value="">Any CKB property</option>
        {properties.map((p) => <option value={p}>{p}</option>)}
      </select>
      <span class="count" id="count">{ideas.length} ideas</span>
    </div>

    <div class="grid" id="grid">
      {
        ideas.map((idea) => (
          <article
            class="card"
            data-title={idea.title.toLowerCase()}
            data-summary={(idea.summary || "").toLowerCase()}
            data-category={idea.category}
            data-difficulty={idea.difficulty}
            data-properties={idea.ckb_properties.join("||")}
          >
            <div>
              <span class="num">#{idea.num}</span>
              <a class="title" href={`/ideas/${idea.id}/`}>{idea.title}</a>
            </div>
            <p class="summary">{idea.summary}</p>
            <div class="meta">
              <span class={`badge diff-${idea.difficulty}`}>{DIFFICULTY_LABEL[idea.difficulty]}</span>
              <span class="badge cat">{idea.category}</span>
              {idea.status !== "open" && <span class="badge status">{STATUS_LABEL[idea.status]}</span>}
              {idea.ckb_properties.slice(0, 2).map((p) => <span class="tag">{p}</span>)}
            </div>
          </article>
        ))
      }
    </div>
    <p class="empty" id="empty" style="display:none">No ideas match those filters.</p>
  </div>

  <script is:inline>
    const q = document.getElementById("q");
    const cat = document.getElementById("category");
    const diff = document.getElementById("difficulty");
    const prop = document.getElementById("property");
    const cards = [...document.querySelectorAll(".card")];
    const count = document.getElementById("count");
    const empty = document.getElementById("empty");

    function apply() {
      const term = q.value.trim().toLowerCase();
      const c = cat.value, d = diff.value, p = prop.value;
      let shown = 0;
      for (const card of cards) {
        const ok =
          (!term || card.dataset.title.includes(term) || card.dataset.summary.includes(term)) &&
          (!c || card.dataset.category === c) &&
          (!d || card.dataset.difficulty === d) &&
          (!p || card.dataset.properties.split("||").includes(p));
        card.style.display = ok ? "" : "none";
        if (ok) shown++;
      }
      count.textContent = shown + (shown === 1 ? " idea" : " ideas");
      empty.style.display = shown ? "none" : "";
    }
    [q, cat, diff, prop].forEach((el) => el.addEventListener("input", apply));
  </script>
</Base>
