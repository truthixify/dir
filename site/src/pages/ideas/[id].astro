---
import Base from "../../layouts/Base.astro";
import { getIdeas, DIFFICULTY_LABEL, STATUS_LABEL, STATE_CLASS } from "../../lib/ideas.js";

export function getStaticPaths() {
  return getIdeas().map((idea) => ({ params: { id: idea.id }, props: { idea } }));
}

const { idea } = Astro.props;
const state = STATE_CLASS[idea.status];
---

<Base title={`#${idea.num} ${idea.title} — dir`} description={idea.summary}>
  <article class="detail wrap">
    <a class="back" href="/">← All ideas</a>

    <!-- hero manifest -->
    <div class="manifest">
      <span class="idtab">DIR · #{idea.num}</span>
      <div class={`band ${state}`}>
        {idea.status !== "open" && <span class="dot" />}
        {STATUS_LABEL[idea.status]} · {idea.category}
      </div>
      <div class="inner">
        <h1><span class="num">#{idea.num}</span>{idea.title}</h1>
        <div class="subtitle mono-caps">{idea.category} · {DIFFICULTY_LABEL[idea.difficulty]}</div>
        <p style="color:#d8d1c3; margin:10px 0 0">{idea.summary}</p>
        <div class="tags">
          <span class={`tag diff diff-${idea.difficulty}`}>{DIFFICULTY_LABEL[idea.difficulty]}</span>
          {idea.ckb_properties.map((p) => <span class="tag">{p}</span>)}
        </div>
      </div>
      <div class="formfoot" style="padding:8px 20px">
        <span>DIR · IDEA MANIFEST · CC0</span>
        <span>#{idea.num} / {String(30).padStart(2, "0")}</span>
      </div>
    </div>

    <!-- metadata -->
    <section class="section">
      <div class="band open">REGISTRY METADATA</div>
      <div class="body">
        <dl class="kv">
          <dt>CKB properties</dt>
          <dd>{idea.ckb_properties.join(" · ")}</dd>
          {idea.primitives?.length && (<><dt>Primitives</dt><dd>{idea.primitives.join(" · ")}</dd></>)}
          {idea.inspired_by && (<><dt>Inspired by</dt><dd>{idea.inspired_by}</dd></>)}
          {idea.needs_collaborators?.length && (<><dt>Wants</dt><dd>{idea.needs_collaborators.join(" · ")}</dd></>)}
          {idea.author && (<><dt>Author</dt><dd>{idea.author}</dd></>)}
          {idea.references?.length && (
            <>
              <dt>References</dt>
              <dd>
                {idea.references.map((r, i) => (
                  <>{i > 0 && " · "}<a href={r.url} target="_blank" rel="noopener">{r.title}</a></>
                ))}
              </dd>
            </>
          )}
        </dl>
      </div>
    </section>

    <!-- acceptance criteria -->
    <section class="section">
      <div class="band open">ACCEPTANCE CRITERIA · SHIPPED MEANS ALL OF THESE</div>
      <div class="body">
        <ul class="criteria">
          {idea.acceptance_criteria.map((c) => <li>{c}</li>)}
        </ul>
      </div>
    </section>

    <!-- rendered spec body -->
    <div class="prose" set:html={idea.html} />
  </article>
</Base>
