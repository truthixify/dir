---
import Base from "../../layouts/Base.astro";
import { getIdeas, DIFFICULTY_LABEL, STATUS_LABEL, STATE_CLASS } from "../../lib/ideas.js";

const ideas = getIdeas();
const categories = [...new Set(ideas.map((i) => i.category))].sort();

const SHORT = {
  "Developer Tooling": "TOOLING",
  "On-Chain Storage & Data Ownership": "STORAGE",
  "Spore/DOB": "SPORE/DOB",
  "RGB++ & Bitcoin": "RGB++",
  "AI Agents": "AI AGENTS",
  "OTX & Intent-Based": "OTX",
  "Fiber Network": "FIBER",
  "Identity & Security": "IDENTITY",
  "Social & Community": "SOCIAL",
};

const goodFirst = ideas.filter((i) => i.difficulty === "good-first").length;
const shipped = ideas.filter((i) => i.status === "shipped").length;
const claimed = ideas.filter((i) => i.status === "claimed" || i.status === "building").length;
const open = ideas.filter((i) => i.status === "open").length;

const statusChips = [
  ["", "All"], ["open", "Open"], ["claimed", "Claimed"], ["building", "Building"], ["shipped", "Shipped"],
];
---

<Base title="Catalog — dir" description="Every CKB-native idea in the registry, indexed by state and signal.">
  <div class="catalog">
    <!-- page header -->
    <section class="pagehead">
      <div class="wrap">
        <span class="mc">DIR · CATALOG</span>
        <h1>The catalog.</h1>
        <p>Every idea in the registry, indexed by state and signal. Pick one and commit.</p>
      </div>
    </section>

    <!-- filter chips -->
    <section class="filterstrip">
      <div class="wrap">
        <span class="mc">FILTER</span>
        {statusChips.map(([v, l]) => (
          <button class={`chip${v === "" ? " active" : ""}`} data-group="status" data-value={v}>{l}</button>
        ))}
        <span class="chip-sep"></span>
        <button class="chip active" data-group="cat" data-value="">All</button>
        {categories.map((c) => (
          <button class="chip" data-group="cat" data-value={c}>{SHORT[c] ?? c}</button>
        ))}
        <span class="sort mc">SORT · BY ID</span>
      </div>
    </section>

    <!-- stat strip -->
    <section class="statbar">
      <div class="wrap">
        <span class="mc"><span id="count">{ideas.length}</span> SHOWN · {open} OPEN · {claimed} CLAIMED · {shipped} SHIPPED · {goodFirst} GOOD-FIRST</span>
      </div>
    </section>

    <!-- rows -->
    <section>
      <div class="wrap" style="padding-top:28px">
        <div class="rows" id="rows">
          {ideas.map((idea) => {
            const sc = STATE_CLASS[idea.status];
            return (
              <div class="row" style={`--stripe: var(--${sc === "open" ? "line" : sc})`} data-status={idea.status} data-category={idea.category}>
                <span class="stripe"></span>
                <span class="mc">#{String(idea.num).padStart(4, "0")}</span>
                <span class={`pill ${sc}`}>{idea.status !== "open" && <span class="pdot"></span>}{STATUS_LABEL[idea.status]}</span>
                <div>
                  <a class="rtitle" href={`/ideas/${idea.id}/`}>{idea.title}</a>
                  <span class="mc rcat" style="display:block">{idea.category}</span>
                </div>
                <span class={`tag diff diff-${idea.difficulty} rcol-hide`}>{DIFFICULTY_LABEL[idea.difficulty]}</span>
                <span class="mc rcol-hide">{idea.ckb_properties[0]}</span>
                <div class="rval rcol-hide">
                  <span class="n">{idea.ckb_properties.length}</span>
                  <span class="l">CKB Props</span>
                </div>
                <a class="btn btn-ghost btn-sm rview" href={`/ideas/${idea.id}/`}>View</a>
              </div>
            );
          })}
        </div>
        <p class="empty" id="empty" style="display:none">No ideas match those filters</p>

        <div class="pager">
          <span class="mc">{ideas.length} IDEAS · ONE PAGE</span>
          <a class="btn btn-violet btn-sm" href="https://github.com/truthixify/dir/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener">Submit an idea →</a>
        </div>
      </div>
    </section>
  </div>

  <script is:inline>
    const rows = [...document.querySelectorAll(".row")];
    const count = document.getElementById("count");
    const empty = document.getElementById("empty");
    const f = { status: "", cat: "" };
    function apply() {
      let n = 0;
      for (const r of rows) {
        const ok = (!f.status || r.dataset.status === f.status) && (!f.cat || r.dataset.category === f.cat);
        r.style.display = ok ? "" : "none";
        if (ok) n++;
      }
      count.textContent = n;
      empty.style.display = n ? "none" : "";
    }
    document.querySelectorAll(".chip").forEach((c) => {
      c.addEventListener("click", () => {
        const g = c.dataset.group;
        document.querySelectorAll(`.chip[data-group="${g}"]`).forEach((x) => x.classList.toggle("active", x === c));
        f[g] = c.dataset.value;
        apply();
      });
    });
  </script>
</Base>
