---
import "../styles/global.css";
const { title = "dir — CKB-native project ideas", description = "An open directory of CKB-native project ideas where builders publicly commit, build, and ship." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href="/"><span class="mark"></span><b>dir</b></a>
        <nav class="nav">
          <a href="/">Ideas</a>
          <a href="https://github.com/truthixify/dir" target="_blank" rel="noopener">Contribute</a>
          <a href="https://github.com/truthixify/dir/blob/main/SPEC.md" target="_blank" rel="noopener">Spec</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="wrap">
        <span class="stamp">DIR · CKB-NATIVE PROJECT DIRECTORY · CC0</span>
        <span class="meta">Ideas CC0 · Code Apache-2.0 · <a href="https://www.nervos.org/" target="_blank" rel="noopener">Nervos CKB</a></span>
      </div>
    </footer>
  </body>
</html>
